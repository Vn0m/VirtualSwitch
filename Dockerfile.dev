FROM --platform=linux/amd64 ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    cmake \
    ninja-build \
    pkg-config \
    git \
    gdb \
    libsodium-dev \
    iproute2 \
    iptables \
    iputils-ping \
    net-tools \
    tcpdump \
    libsdl2-2.0-0 \
    libsdl2-mixer-2.0-0 \
    libopenal1 \
    libpng16-16 \
    libfontconfig1 \
    libx11-6 \
    libxext6 \
    libxrandr2 \
    libxinerama1 \
    libxcursor1 \
    libxi6 \
    libxxf86vm1 \
    curl \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace
